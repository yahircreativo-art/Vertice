---
import Layout from '../layouts/Layout.astro'

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Vertice Studio",
  url: "https://vertice.dev",
  logo: "https://vertice.dev/favicon.png",
  description: "Agencia de diseño web, branding y marketing digital.",  sameAs: [
    "https://www.instagram.com/verticestudio",
    "https://www.linkedin.com/company/verticestudio"
  ]
};
---
<Layout
  title="Vertice Studio - Modern Web Development"
  description="Your one-stop solution for modern web development."
  canonical="https://yahircreativo-art.github.io/Vertice/"
  schema={schema}
>
  <main class="container mx-auto px-4 py-16">
	<h1 class="text-4xl font-bold mb-4">Welcome to Vertice Studio</h1>
	<p class="text-lg mb-8">
	  We specialize in creating stunning websites, branding, and digital marketing strategies that help your business stand out online.
	</p>
	<a href="/contact" class="bg-blue-600 text-white px-6 py-3 rounded hover:bg-blue-700 transition">
	  Contact Us
	</a>
  </main>